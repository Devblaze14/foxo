# Copy to .env to override defaults. All values are optional.

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# Local default (zero setup): a SQLite file next to the app.
DATABASE_URL=sqlite:///./inventory.db

# --- Hosted Postgres via Supabase ------------------------------------------
# In the Supabase dashboard click "Connect" and copy the *Session pooler* URI
# (recommended for a long-running server: it's IPv4-friendly and works with
# SQLAlchemy out of the box). Then make two edits:
#   1. change the scheme  postgresql://  ->  postgresql+psycopg2://
#   2. keep the username in the form  postgres.<PROJECT_REF>
#
# Session pooler (recommended for this app):
# DATABASE_URL=postgresql+psycopg2://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require
#
# Direct connection (simplest locally, but IPv6-only on some networks):
# DATABASE_URL=postgresql+psycopg2://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require

# ---------------------------------------------------------------------------
# MISC
# ---------------------------------------------------------------------------
# Log every SQL statement (useful when inspecting transactions).
SQL_ECHO=false

# Retries on an optimistic-lock conflict before returning 409.
MAX_WRITE_RETRIES=5
