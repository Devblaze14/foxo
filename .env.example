# Copy this file to .env and adjust if needed. All values are optional.

# The database connection. The default is a local SQLite file, so the project
# runs with no setup. To use PostgreSQL, set this to your connection string, for
# example:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=sqlite:///./inventory.db

# Set to true to print SQL statements while the app runs.
SQL_ECHO=false

# How many times to retry a movement if two updates collide before giving up.
MAX_WRITE_RETRIES=5
